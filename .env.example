# 复制此文件为 .env 并填写真实值，.env 不会被提交到版本控制。

# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-flask-secret-key

# ── 火山引擎 TOS 对象存储 ─────────────────────────────────────────────────────
VOLC_TOS_AK=your-tos-access-key
VOLC_TOS_SK=your-tos-secret-key

# ── 火山引擎 ASR（大模型转写）────────────────────────────────────────────────
VOLC_ASR_APPID=your-asr-appid
VOLC_ASR_TOKEN=your-asr-token

# ── 火山引擎 Ark 大模型（文本评分）──────────────────────────────────────────
VOLC_ARK_API_KEY=your-ark-api-key
